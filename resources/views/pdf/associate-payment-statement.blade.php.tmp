        </thead>
        <tbody>
            @foreach ($distributions as $d)
            @php
                $dGross  = (float) $d->gross_value;
                $dNet    = (float) $d->net_value;
                $dFeeAmt = $dGross - $dNet;
                $dFeeP   = $dGross > 0 ? round($dFeeAmt / $dGross * 100, 1) : 0;
            @endphp
            <tr>
                <td style="text-align:center">{{ $d->delivery_date?->format('d/m/Y') ?? '—' }}</td>
                <td>{{ optional($d->product)->name ?? '—' }}</td>
                <td>{{ optional($d->customer)->trade_name ?? optional($d->customer)->name ?? '—' }}</td>
                <td style="text-align:right">{{ number_format((float)$d->quantity, 3, ',', '.') }}&nbsp;{{ optional($d->product)->unit ?? '' }}</td>
                <td style="text-align:right">R$&nbsp;{{ number_format($dGross, 2, ',', '.') }}</td>
                <td style="text-align:center">{{ number_format($dFeeP, 1, ',', '.') }}%</td>
                <td style="text-align:right;font-weight:600;color:#059669">R$&nbsp;{{ number_format($dNet, 2, ',', '.') }}</td>
            </tr>
            @endforeach
        </tbody>
        <tfoot>
            <tr class="total-row">
                <td colspan="4" style="text-align:right">Subtotais:</td>
                <td style="text-align:right">R$&nbsp;{{ number_format($totalGross, 2, ',', '.') }}</td>
                <td></td>
                <td style="text-align:right;color:#059669">R$&nbsp;{{ number_format($totalNet, 2, ',', '.') }}</td>
            </tr>
        </tfoot>
    </table>

    {{-- RESUMO FINANCEIRO --}}
    <div class="financial-summary">
        <table style="width:100%;border-collapse:collapse">
            <tr>
                <td class="fs-label">Total Bruto das Distribuições</td>
                <td class="fs-value">R$&nbsp;{{ number_format($totalGross, 2, ',', '.') }}</td>
            </tr>
            <tr>
                <td class="fs-label">Taxa Administrativa ({{ $adminFee }}%)</td>
                <td class="fs-value danger">- R$&nbsp;{{ number_format($totalFees, 2, ',', '.') }}</td>
            </tr>
            <tr class="fs-highlight">
                <td class="fs-label">Líquido das Distribuições</td>
                <td class="fs-value success">R$&nbsp;{{ number_format($totalNet, 2, ',', '.') }}</td>
            </tr>
            <tr class="fs-paid">
                <td class="fs-label bold">Valor Pago Neste Extrato</td>
                <td class="fs-value success bold">R$&nbsp;{{ number_format($amountPaid, 2, ',', '.') }}</td>
            </tr>
            @if ($balance > 0)
            <tr class="fs-balance">
                <td class="fs-label">Saldo em Aberto (Parcelas Futuras)</td>
