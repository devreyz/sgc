@extends('pdf.partials.header')

@section('content')
@php
    /** @var \App\Models\Tenant          $tenant */
    /** @var \App\Models\SalesProject    $project */
    /** @var \App\Models\ProjectPayment  $payment */
    /** @var \Illuminate\Support\Collection $distributions */
    $associateName  = $associate_name ?? '—';
    $cpf            = $cpf ?? '—';
    $genAt          = $generated_at ?? now()->format('d/m/Y H:i');
    $adminFee       = optional($project)->admin_fee_percentage ?? 0;

    $totalGross     = $distributions->sum('gross_value');
    $totalFees      = $distributions->sum(fn ($d) => $d->gross_value - $d->net_value);
    $totalNet       = $distributions->sum('net_value');
    $amountPaid     = (float) optional($payment)->amount;
    $balance        = (float) optional($payment)->balance_remaining;
    $payMethod      = optional($payment)->payment_method?->getLabel() ?? '—';
    $docNum         = optional($payment)->document_number ?? '—';
    $payDate        = optional($payment)->payment_date?->format('d/m/Y') ?? '—';
    $receiptNum     = optional($payment)->receipt_number ?? '—';

    $copies = [
        '1ª VIA — ASSOCIADO',
        '2ª VIA — ASSOCIAÇÃO / COOPERATIVA',
    ];
@endphp

